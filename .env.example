# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/nestlaunch"

# ─── API (NestJS) ────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001

JWT_SECRET=change-this-to-a-very-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-secret
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

# ─── Web (Next.js) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── PostgreSQL (Docker) ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=nestlaunch
